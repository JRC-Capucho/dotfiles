[core]
    excludesfile = ~/.gitignore
    editor = nvim
    ignorecase = false
[color]
    status = auto
    diff = auto
    branch = auto
    interactive = auto
    grep = auto
    ui = auto
[alias]
    d = diff
    co = checkout
    ci = commit
    ca = commit -a
    ps = push
    pl = pull
    st = status
    br = branch
    ba = branch -a
    bm = branch --merged
    bn = branch --no-merged
    staash = stash --all
[hub]
    protocol = https
[github]
    user = JRC-Capucho
[ghq]
    root = ~/.ghq
[user]
	email = joaorobertoc.capucho@gmail.com
	name = JRC-Capucho
  signingkey = ~/.ssh/id_ed25519.pub
[gpg]
  format = ssh
[branch]
  sort = -committerdate
[commit]
  gpgsign = true
[column]
  ui = auto
[rerere]
  enabled = true
