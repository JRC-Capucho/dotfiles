[core]
    excludesfile = ~/.gitignore
    editor = nvim
    ignorecase = false
[color]
    status = auto
    diff = auto
    branch = auto
    interactive = auto
    grep = auto
    ui = auto
[alias]
    d = diff
    co = checkout
    ci = commit
    ca = commit -a
    ps = push
    pl = pull
    st = status
    br = branch
    ba = branch -a
    bm = branch --merged
    bn = branch --no-merged
[hub]
    protocol = https
[github]
    user = JRC-Capucho
[ghq]
    root = ~/.ghq
[user]
	email = joaorobertoc.capucho@gmail.com
	name = JRC-Capucho
